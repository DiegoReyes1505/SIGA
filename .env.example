# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos MySQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=siga_db

# ── Agente local (comunicación sensor → servidor) ────────────
AGENT_PORT=3001
SERVER_URL=http://localhost:3000
AGENT_SECRET=clave_secreta_agente_aqui

# ── Serial (agente local) ────────────────────────────────────
SERIAL_PORT=COM3         # En Linux: /dev/ttyUSB0 o /dev/ttyACM0
SERIAL_BAUD=9600
